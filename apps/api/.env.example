# Spring Boot API — переменные окружения
# Скопируй в .env и заполни реальными значениями. .env в gitignore.
# Правило: если required-переменная (без default в application.yml) не установлена — приложение падает на старте.
# Проверить соответствие application.yml ↔ этот файл: scripts/check-env.sh --template

# === Database === (required)
# PostgreSQL (docker compose локально, managed в prod)
DB_URL=jdbc:postgresql://localhost:5432/reinasleo
DB_USER=reinasleo
DB_PASSWORD=

# === Auth === (required)
# Минимум 32 байта (256 бит). Генерировать: openssl rand -base64 48
JWT_SECRET=
# Общий секрет между Spring Boot и Python ботом для X-Bot-Secret header
BOT_API_SECRET=
# Required — TTL JWT в ms (24h = 86400000). Default убран: без явного значения сервис падает на старте.
JWT_EXPIRATION_MS=86400000

# === CORS === (required)
# Разрешённые origins через запятую, e.g. https://reinasleo.com,https://www.reinasleo.com
CORS_ORIGIN=

# === Email (Resend.com) === (required: RESEND_API_KEY)
RESEND_API_KEY=
# Опциональный override (default в yml: "REINASLEO <noreply@reinasleo.com>")
RESEND_FROM=

# === Telegram ===
# Опциональный override username бота (default в yml: reinasleo_bot)
BOT_USERNAME=
# Bot token из @BotFather. Используется для sendMessage из TelegramNotifier
# (одноразовые коды удаления аккаунта). Required — без него падаем на старте.
TELEGRAM_BOT_TOKEN=

# === Uploads ===
# Опциональный override папки загрузок (default в yml: uploads)
UPLOAD_DIR=

# === Metrics === (required)
# Shared secret для скрейпера Prometheus. Передаётся в header X-Metrics-Secret
# при GET /actuator/prometheus. Генерировать: openssl rand -base64 32
METRICS_SECRET=
