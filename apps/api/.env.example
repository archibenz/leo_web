# Spring Boot API — переменные окружения
# Скопируй в .env и заполни реальными значениями. .env в gitignore.
# Правило: если переменная не установлена — приложение должно падать на старте, не использовать fallback.

# === Database ===
# PostgreSQL (docker compose локально, managed в prod)
DB_URL=jdbc:postgresql://localhost:5432/reinasleo
DB_USER=reinasleo
DB_PASSWORD=

# === Auth ===
# Минимум 32 байта (256 бит). Генерировать: openssl rand -base64 48
JWT_SECRET=
# Общий секрет между Spring Boot и Python ботом для X-Bot-Secret header
BOT_API_SECRET=

# === Email (Resend.com) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@reinasleo.com

# === Telegram ===
TELEGRAM_BOT_USERNAME=reinasleo_bot
