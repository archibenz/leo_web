# Next.js Frontend — переменные окружения
# Скопируй в .env.local и заполни реальными значениями. .env.local в gitignore.
# Public-переменные (NEXT_PUBLIC_*) попадают в клиентский bundle — не класть туда секреты.

# === API ===
# Базовый URL Spring Boot API. Прод: https://reinasleo.com (nginx проксирует /api → :8080).
# Dev: http://localhost:8080.
NEXT_PUBLIC_API_BASE=http://localhost:8080

# === Абсолютные URL (SEO / canonical / OpenGraph) ===
# Используется в metadata + sitemap. Без завершающего слеша.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
