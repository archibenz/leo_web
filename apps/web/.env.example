# Next.js Frontend — переменные окружения
# Скопируй в .env.local и заполни реальными значениями. .env.local в gitignore.
# Public-переменные (NEXT_PUBLIC_*) попадают в клиентский bundle — не класть туда секреты.

# === API ===
# Базовый URL Spring Boot API. Прод: https://reinasleo.com (nginx проксирует /api → :8080).
# Dev: http://localhost:8080.
NEXT_PUBLIC_API_BASE=http://localhost:8080

# === Абсолютные URL (SEO / canonical / OpenGraph) ===
# Используется в metadata + sitemap. Без завершающего слеша.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Newsletter (Resend Audience) ===
# Опционально. Если оба заданы — POST /api/newsletter/subscribe добавляет email
# в Resend audience. Без них endpoint отвечает 503 и фронт показывает generic
# error. Создать audience в Resend dashboard → "Audiences" → "Add audience".
# Backend (Spring Boot) использует свой собственный RESEND_API_KEY для
# transactional email — для contacts API можно использовать тот же ключ
# (Resend allows shared API keys with full scope).
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
