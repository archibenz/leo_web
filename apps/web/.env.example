# Next.js Frontend — переменные окружения
# Скопируй в .env и заполни реальными значениями. .env в gitignore.

# === API ===
DATABASE_URL=postgresql://reinasleo:PASSWORD@localhost:5432/reinasleo
# JWT_SECRET должен совпадать с backend (apps/api/.env)
JWT_SECRET=

# === Public (попадает в клиентский bundle — не секрет) ===
NEXT_PUBLIC_SITE_URL=https://reinasleo.com
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=reinasleo_bot

# === Bot integration ===
# Должен совпадать с BOT_API_SECRET на backend и X_BOT_SECRET у бота
TELEGRAM_BOT_SECRET=
